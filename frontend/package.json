{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "npm run sync:content-assets && vite",
    "prebuild": "npm run sync:content-assets",
    "sync:content-assets": "node ../scripts/sync-content-assets.mjs",
    "generate:sitemap": "node ../scripts/generate-sitemap.mjs",
    "build:client": "vite build",
    "build": "npm run generate:sitemap && npm run build:client && node ../scripts/prerender-static.mjs",
    "preview": "vite preview"
  },
  "dependencies": {
    "markdown-it": "^14.1.1",
    "vue": "^3.5.30",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.5",
    "vite": "^8.0.1"
  }
}
